---
---

<footer class="relative pt-20 pb-10">
  <!-- Divider -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[min(80%,600px)] h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-10 mb-16">
      <!-- Logo & tagline -->
      <div class="flex items-center gap-3">
        <svg width="28" height="34" viewBox="0 0 40 48" fill="none">
          <rect x="0" y="0" width="40" height="48" rx="3" fill="#F5A623" />
          <rect x="6" y="6" width="28" height="36" rx="2" fill="#0A0A0F" />
          <rect x="11" y="11" width="18" height="26" rx="1.5" fill="#F5A623" />
          <rect x="16" y="16" width="8" height="16" rx="1" fill="#0A0A0F" />
        </svg>
        <div>
          <span class="font-display font-bold text-base tracking-tight text-white leading-none block">
            PLUS <span class="text-accent">VENDING</span>
          </span>
          <span class="text-[11px] text-white/50 tracking-wide">Distributori Automatici</span>
        </div>
      </div>

      <!-- Quick links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        <a href="/#servizi" class="text-[13px] text-white/60 hover:text-accent transition-colors duration-300">Servizi</a>
        <a href="/distributori" class="text-[13px] text-white/60 hover:text-accent transition-colors duration-300">Distributori</a>
        <a href="/#perche-noi" class="text-[13px] text-white/60 hover:text-accent transition-colors duration-300">Perché noi</a>
        <a href="/#chi-siamo" class="text-[13px] text-white/60 hover:text-accent transition-colors duration-300">Chi siamo</a>
        <a href="/#contatti" class="text-[13px] text-white/60 hover:text-accent transition-colors duration-300">Contatti</a>
      </nav>

      <!-- Social -->
      <div class="flex items-center gap-3">
        <a
          href="https://www.instagram.com/plusvendingsrls/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram Plus Vending"
          class="group flex items-center justify-center w-10 h-10 rounded-full border border-white/[0.12] bg-white/[0.03] hover:border-accent hover:bg-accent/10 transition-all duration-300"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-white/60 group-hover:text-accent transition-colors duration-300">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" fill="currentColor"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=61574042603021"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook Plus Vending"
          class="group flex items-center justify-center w-10 h-10 rounded-full border border-white/[0.12] bg-white/[0.03] hover:border-accent hover:bg-accent/10 transition-all duration-300"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="text-white/60 group-hover:text-accent transition-colors duration-300">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="currentColor"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-white/[0.08]">
      <p class="text-[12px] text-white/40 text-center md:text-left">
        &copy; {new Date().getFullYear()} Plus Vending s.r.l.s — P.IVA 05764060652
      </p>
      <div class="flex flex-col md:flex-row items-center gap-2 md:gap-5">
        <p class="text-[12px] text-white/40 text-center">
          Via Alfonso Albanese, 43 — 84010 S.Egidio del Monte Albino (SA)
        </p>
        <a href="/privacy" class="text-[12px] text-white/40 hover:text-accent transition-colors duration-300">
          Privacy Policy
        </a>
        <a href="#" data-cookie-manage class="text-[12px] text-white/40 hover:text-accent transition-colors duration-300">
          Gestisci cookie
        </a>
      </div>
    </div>
  </div>
</footer>
