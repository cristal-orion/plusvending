---
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-header">
  <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <svg
        width="32"
        height="38"
        viewBox="0 0 40 48"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="transition-transform duration-500 group-hover:scale-110"
      >
        <rect x="0" y="0" width="40" height="48" rx="3" fill="#F5A623" />
        <rect x="6" y="6" width="28" height="36" rx="2" fill="#0A0A0F" class="header-logo-gap" />
        <rect x="11" y="11" width="18" height="26" rx="1.5" fill="#F5A623" />
        <rect x="16" y="16" width="8" height="16" rx="1" fill="#0A0A0F" class="header-logo-gap" />
      </svg>
      <span class="font-display font-bold text-lg tracking-tight text-text leading-none">
        PLUS<br /><span class="text-accent">VENDING</span>
      </span>
    </a>

    <!-- Nav — desktop -->
    <nav class="hidden md:flex items-center gap-10">
      <a href="/#servizi" class="nav-link text-[13px] font-medium uppercase tracking-[0.15em] text-white/80 hover:text-accent transition-colors duration-300">
        Servizi
      </a>
      <a href="/distributori" class="nav-link text-[13px] font-medium uppercase tracking-[0.15em] text-white/80 hover:text-accent transition-colors duration-300">
        Distributori
      </a>
      <a href="/negozi-h24" class="nav-link text-[13px] font-medium uppercase tracking-[0.15em] text-white/80 hover:text-accent transition-colors duration-300">
        Negozi H24
      </a>
      <a href="/#perche-noi" class="nav-link text-[13px] font-medium uppercase tracking-[0.15em] text-white/80 hover:text-accent transition-colors duration-300">
        Perché noi
      </a>
      <a href="/#chi-siamo" class="nav-link text-[13px] font-medium uppercase tracking-[0.15em] text-white/80 hover:text-accent transition-colors duration-300">
        Chi siamo
      </a>
      <a href="/#contatti" class="nav-link text-[13px] font-medium uppercase tracking-[0.15em] text-white/80 hover:text-accent transition-colors duration-300">
        Contatti
      </a>
    </nav>

    <div class="flex items-center gap-4">
      <!-- CTA — hidden on mobile, visible in mobile menu instead -->
      <a
        href="/#contatti"
        class="cta-btn hidden md:inline-flex relative items-center gap-2 px-6 py-2.5 bg-accent text-bg font-body font-semibold text-sm rounded-lg overflow-hidden transition-all duration-300 hover:shadow-[0_0_32px_rgba(245,166,35,0.3)]"
      >
        <span class="relative z-10">Richiedi Info</span>
      </a>

      <!-- Hamburger — mobile only -->
      <button
        id="menu-toggle"
        class="md:hidden relative z-[110] flex flex-col justify-center items-center w-10 h-10 gap-[5px]"
        aria-label="Apri menu"
        aria-expanded="false"
      >
        <span class="hamburger-line block w-6 h-[2px] bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-[2px] bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-[2px] bg-white rounded-full transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

</header>

<!-- Mobile nav overlay — outside header to avoid z-index stacking issues -->
<div id="mobile-menu" class="mobile-menu md:hidden fixed inset-0 z-[100] pointer-events-none opacity-0 transition-opacity duration-300">
  <div id="mobile-backdrop" class="absolute inset-0 bg-bg/95 backdrop-blur-xl"></div>
  <nav class="relative z-10 flex flex-col items-center justify-center h-full gap-10">
    <a href="/#servizi" class="mobile-nav-link text-2xl font-medium uppercase tracking-[0.2em] text-white/80 hover:text-accent transition-colors duration-300">
      Servizi
    </a>
    <a href="/distributori" class="mobile-nav-link text-2xl font-medium uppercase tracking-[0.2em] text-white/80 hover:text-accent transition-colors duration-300">
      Distributori
    </a>
    <a href="/negozi-h24" class="mobile-nav-link text-2xl font-medium uppercase tracking-[0.2em] text-white/80 hover:text-accent transition-colors duration-300">
      Negozi H24
    </a>
    <a href="/#perche-noi" class="mobile-nav-link text-2xl font-medium uppercase tracking-[0.2em] text-white/80 hover:text-accent transition-colors duration-300">
      Perché noi
    </a>
    <a href="/#chi-siamo" class="mobile-nav-link text-2xl font-medium uppercase tracking-[0.2em] text-white/80 hover:text-accent transition-colors duration-300">
      Chi siamo
    </a>
    <a href="/#contatti" class="mobile-nav-link text-2xl font-medium uppercase tracking-[0.2em] text-white/80 hover:text-accent transition-colors duration-300">
      Contatti
    </a>
    <!-- CTA in mobile menu -->
    <a
      href="/#contatti"
      class="mt-4 inline-flex items-center gap-2 px-8 py-3 bg-accent text-bg font-body font-semibold text-base rounded-lg transition-all duration-300"
    >
      Richiedi Info
    </a>
  </nav>
</div>

<style>
  .cta-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }
  .cta-btn:hover::before {
    transform: translateX(100%);
  }

  /* Hamburger → X animation */
  .menu-open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Light header hamburger lines */
  :global(.header-light) .hamburger-line {
    background-color: #1A1A24;
  }

  /* Mobile menu open state — global because overlay is outside <header> */
  :global(.mobile-menu.is-open) {
    opacity: 1;
    pointer-events: auto;
  }

  /* Scrolled over dark area (hero) — keep text bright */
  :global(.header-scrolled):not(:global(.header-light)) .nav-link {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Light mode header when over content area */
  :global(.header-light) .nav-link {
    color: #555;
  }
  :global(.header-light) .nav-link:hover {
    color: #F5A623;
  }
  :global(.header-light) span.text-text {
    color: #1A1A24;
  }
  :global(.header-light) .header-logo-gap {
    fill: #FAFAF7;
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const gaps = document.querySelectorAll('.header-logo-gap');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu!.classList.add('is-open');
    menuToggle!.classList.add('menu-open');
    menuToggle!.setAttribute('aria-expanded', 'true');
    header!.style.zIndex = '150';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu!.classList.remove('is-open');
    menuToggle!.classList.remove('menu-open');
    menuToggle!.setAttribute('aria-expanded', 'false');
    header!.style.zIndex = '';
    document.body.style.overflow = '';
  }

  // Mobile menu toggle
  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu!.classList.contains('is-open');
    isOpen ? closeMenu() : openMenu();
  });

  // Close menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close menu on backdrop tap (anywhere that's not a link)
  mobileMenu?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('a')) {
      closeMenu();
    }
  });

  const moldingOuter = document.querySelector('.molding-outer') as HTMLElement;

  window.addEventListener('scroll', () => {
    const overLight = moldingOuter && window.scrollY >= moldingOuter.offsetTop - 80;

    if (window.scrollY > 60) {
      header!.classList.add('header-scrolled');
      if (overLight) {
        header!.style.backgroundColor = 'rgba(250, 250, 247, 0.92)';
        header!.classList.add('header-light');
      } else {
        header!.style.backgroundColor = 'rgba(10, 10, 15, 0.88)';
        header!.classList.remove('header-light');
      }
      header!.style.backdropFilter = 'blur(24px)';
      header!.style.webkitBackdropFilter = 'blur(24px)';
      header!.style.borderBottom = overLight ? '1px solid rgba(0,0,0,0.06)' : '1px solid rgba(245, 166, 35, 0.08)';
    } else {
      header!.style.backgroundColor = 'transparent';
      header!.style.backdropFilter = 'none';
      header!.style.webkitBackdropFilter = 'none';
      header!.style.borderBottom = '1px solid transparent';
      header!.classList.remove('header-light');
      header!.classList.remove('header-scrolled');
    }
  });
</script>
