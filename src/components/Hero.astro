---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20" id="hero">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/heroimg.png" alt="" class="w-full h-full object-cover object-center" />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center flex flex-col items-center">
    <!-- Headline -->
    <div class="mb-7 flex flex-col items-center gap-1 animate-fade-up" style="animation-delay: 0.2s;">
      <div class="hero-frost hero-frost--title">
        <span class="font-display font-extrabold text-[clamp(2.8rem,7vw,6.5rem)] leading-[1.05] tracking-tight text-text">Non vendiamo<br/>distributori.</span>
      </div>
      <div class="hero-frost hero-frost--title" style="margin-top: 4px;">
        <span class="hero-accent-text font-display font-extrabold text-[clamp(2.8rem,7vw,6.5rem)] leading-[0.92] tracking-tight">Costruiamo business.</span>
      </div>
    </div>

    <!-- Description -->
    <div class="hero-frost mb-11 max-w-xl animate-fade-up" style="animation-delay: 0.45s;">
      <p class="text-lg md:text-xl leading-relaxed text-text">
        Dal singolo distributore al negozio automatico H24 completo.
        Consulenza, vendita e assistenza tecnica.
      </p>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up" style="animation-delay: 0.7s;">
      <a href="#contatti" class="hero-cta-primary group px-9 py-4 bg-accent text-bg font-body font-bold text-base rounded-xl transition-all duration-400">
        <span class="flex items-center gap-2">
          Richiedi Informazioni
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-transform duration-300 group-hover:translate-x-1">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
      <a href="#servizi" class="hero-frost px-9 py-4 font-body font-medium text-base text-text rounded-xl transition-all duration-400" style="border-radius: 0.75rem;">
        Scopri i servizi
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-float opacity-40">
    <div class="w-[22px] h-[34px] border-[1.5px] border-text-muted/40 rounded-full flex items-start justify-center pt-2">
      <div class="w-[3px] h-[6px] bg-accent rounded-full animate-[fade-up_1.8s_ease-in-out_infinite]"></div>
    </div>
  </div>
</section>

<style>
  /* Frosted glass pill — pre-blurred image as fixed background */
  .hero-frost {
    display: inline-block;
    padding: 0.6em 1.2em;
    border-radius: 30px;
    background: url('/heroimg-blur.png') center / cover fixed;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 0 2000px rgba(10, 10, 15, 0.1);
  }

  .hero-frost--title {
    width: 100%;
    max-width: 750px;
    text-align: center;
  }

  /* Headline accent shimmer */
  .hero-accent-text {
    background: linear-gradient(135deg, #F5A623 0%, #FFD080 50%, #F5A623 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: text-shimmer 4s ease-in-out infinite;
  }

  @keyframes text-shimmer {
    0%, 100% { background-position: 0% center; }
    50%      { background-position: 200% center; }
  }

  /* Primary CTA glow */
  .hero-cta-primary {
    box-shadow: 0 0 0 rgba(245, 166, 35, 0);
  }
  .hero-cta-primary:hover {
    box-shadow: 0 4px 40px rgba(245, 166, 35, 0.28);
    background-color: #FFB940;
  }
</style>
