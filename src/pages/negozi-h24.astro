---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const videos = [
  { src: '/negozio/1_con_musica-1.mp4', num: '01' },
  { src: '/negozio/2.mp4',               num: '02' },
  { src: '/negozio/3_con_musica.mp4',    num: '03' },
  { src: '/negozio/4_con_musica.mp4',    num: '04' },
  { src: '/negozio/5.mp4',               num: '05' },
  { src: '/negozio/6_con_musica.mp4',    num: '06' },
  { src: '/negozio/7_con_musica.mp4',    num: '07' },
];

const photos = [
  '/negozio/9-768x1024.jpg',
  '/negozio/1orizzontale-1024x576.jpg',
  '/negozio/10-768x1024.jpg',
  '/negozio/7-768x1024.jpg',
  '/negozio/2orizzontale-1024x576.jpg',
  '/negozio/5-768x1024.jpg',
  '/negozio/6-768x1024.jpg',
  '/negozio/4-768x1024.jpg',
  '/negozio/3-768x1024.jpg',
  '/negozio/1-768x1024.jpg',
];
---

<Layout
  title="I nostri negozi H24 — Plus Vending"
  description="Scopri i negozi automatici H24 di Plus Vending: foto e video dei nostri spazi in Campania. Aperto sempre, senza personale."
>
  <Header />

  <main>
    <!-- ══ HERO ══ -->
    <section class="h24-hero relative min-h-[65vh] md:min-h-[58vh] flex items-end overflow-hidden">
      <div class="absolute inset-0 bg-bg">
        <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 60% 40%, rgba(245,166,35,0.07) 0%, transparent 70%);"></div>
        <div class="absolute inset-0 opacity-[0.025]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 80px, rgba(245,166,35,0.4) 80px, rgba(245,166,35,0.4) 81px), repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(245,166,35,0.4) 80px, rgba(245,166,35,0.4) 81px);"></div>
      </div>

      <!-- Floating orbs -->
      <div class="absolute top-16 right-[15%] w-80 h-80 rounded-full bg-accent/[0.05] blur-[100px]"></div>
      <div class="absolute bottom-24 left-[8%] w-64 h-64 rounded-full bg-accent/[0.04] blur-[80px]"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 pb-20 pt-36 w-full">
        <div class="animate-fade-up" style="animation-delay:0.1s">
          <p class="text-[11px] font-body font-semibold tracking-[0.25em] uppercase text-accent mb-5">Esplora i nostri spazi</p>
          <h1 class="font-display font-extrabold text-5xl md:text-[4.8rem] lg:text-[5.8rem] leading-[1.02] tracking-tight text-text mb-6">
            I nostri<br />
            <span class="h24-gradient">negozi H24</span>
          </h1>
          <p class="text-lg md:text-xl text-text-muted max-w-lg leading-relaxed">
            Spazi pensati per chi non ha tempo. Aperti giorno e notte, senza attese, senza personale.
          </p>
        </div>

      </div>

      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-accent to-transparent"></div>
    </section>

    <!-- ══ MOLDING CONTENT ══ -->
    <div class="molding-outer">
      <div class="molding-wrapper" id="molding">
        <div class="molding-content">

          <!-- ── VIDEO SECTION ── -->
          <section class="py-24 md:py-32 px-6">
            <div class="max-w-6xl mx-auto">

              <div class="flex items-end justify-between mb-14" data-reveal>
                <div>
                  <p class="text-[11px] font-body font-semibold tracking-[0.22em] uppercase text-accent mb-3">Tour in video</p>
                  <h2 class="font-display font-bold text-3xl md:text-[2.8rem] leading-[1.08] tracking-tight text-[#1A1A24]">
                    Vivi l'esperienza<br class="hidden sm:block" />
                    <span class="text-accent">dal vivo</span>
                  </h2>
                </div>
                <p class="hidden md:block text-[13px] text-[#888] max-w-[220px] text-right leading-relaxed">
                  Clicca su un video per guardarlo a schermo intero
                </p>
              </div>

              <!-- Video grid -->
              <div class="video-grid">
                {videos.map((v, i) => (
                  <button
                    class="video-card group"
                    data-src={v.src}
                    data-reveal={`delay-${(i % 3) + 1}`}
                  >
                    {/* Thumbnail video */}
                    <video
                      class="video-thumb"
                      src={v.src}
                      preload="metadata"
                      muted
                      playsinline
                      loop
                    />

                    {/* Overlay */}
                    <div class="video-overlay">
                      <span class="video-num">{v.num}</span>
                      <div class="play-btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                          <polygon points="5,3 19,12 5,21" />
                        </svg>
                      </div>
                    </div>
                  </button>
                ))}
              </div>
            </div>
          </section>

          <!-- Divider -->
          <div class="mx-auto w-[min(80%,600px)] h-px bg-gradient-to-r from-transparent via-[#ddd] to-transparent"></div>

          <!-- ── PHOTO SECTION ── -->
          <section class="py-24 md:py-32 px-6">
            <div class="max-w-6xl mx-auto">

              <div class="mb-14" data-reveal>
                <p class="text-[11px] font-body font-semibold tracking-[0.22em] uppercase text-accent mb-3">Galleria fotografica</p>
                <h2 class="font-display font-bold text-3xl md:text-[2.8rem] leading-[1.08] tracking-tight text-[#1A1A24]">
                  Ogni spazio,<br class="hidden sm:block" />
                  <span class="text-accent">un'atmosfera</span>
                </h2>
              </div>

              <!-- Masonry photo grid -->
              <div class="photo-masonry">
                {photos.map((src, i) => (
                  <button
                    class="photo-card group"
                    data-src={src}
                    data-reveal={`delay-${(i % 4) + 1}`}
                  >
                    <img src={src} alt={`Negozio H24 — ${i + 1}`} loading="lazy" class="photo-img" />
                    <div class="photo-overlay">
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
                        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                      </svg>
                    </div>
                  </button>
                ))}
              </div>
            </div>
          </section>

          <!-- ── PARTNER STRIP ── -->
          <section class="relative py-20 overflow-hidden">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[min(80%,600px)] h-px bg-gradient-to-r from-transparent via-[#ddd] to-transparent"></div>

            <div class="text-center mb-12" data-reveal>
              <p class="text-[11px] font-body font-semibold tracking-[0.22em] uppercase text-accent mb-3">Con chi lavoriamo</p>
              <h2 class="font-display font-bold text-3xl md:text-[2.4rem] leading-[1.1] tracking-tight text-[#1A1A24]">
                I nostri <span class="text-accent">partner</span>
              </h2>
            </div>

            <!-- Strip infinita -->
            <div class="partner-track-wrap">
              <!-- Fade edges -->
              <div class="partner-fade-left"></div>
              <div class="partner-fade-right"></div>

              <div class="partner-track">
                {[
                  { src: '/partner/tcn-1.png',        alt: 'TCN' },
                  { src: '/partner/ziwi.jpg',          alt: 'Zilli' },
                  { src: '/partner/logomarkitaly.png', alt: 'Mark Italy' },
                  { src: '/partner/Nayax.png',         alt: 'Nayax' },
                  { src: '/partner/CPI.png',           alt: 'CPI' },
                  { src: '/partner/LOGO-NECTA.png',    alt: 'Necta' },
                  { src: '/partner/fas.png',           alt: 'FAS' },
                  { src: '/partner/sandevendo.png',    alt: 'Sandevendo' },
                  /* duplicate for seamless loop */
                  { src: '/partner/tcn-1.png',        alt: 'TCN' },
                  { src: '/partner/ziwi.jpg',          alt: 'Zilli' },
                  { src: '/partner/logomarkitaly.png', alt: 'Mark Italy' },
                  { src: '/partner/Nayax.png',         alt: 'Nayax' },
                  { src: '/partner/CPI.png',           alt: 'CPI' },
                  { src: '/partner/LOGO-NECTA.png',    alt: 'Necta' },
                  { src: '/partner/fas.png',           alt: 'FAS' },
                  { src: '/partner/sandevendo.png',    alt: 'Sandevendo' },
                ].map((p) => (
                  <div class="partner-item">
                    <img src={p.src} alt={p.alt} loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- ── CTA BOTTOM ── -->
          <section class="relative py-24 overflow-hidden">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[min(80%,600px)] h-px bg-gradient-to-r from-transparent via-[#ddd] to-transparent"></div>
            <div class="max-w-4xl mx-auto px-6 text-center" data-reveal>
              <p class="text-[11px] font-body font-semibold tracking-[0.22em] uppercase text-accent mb-4">Apri il tuo negozio</p>
              <h2 class="font-display font-bold text-3xl md:text-[2.8rem] leading-[1.1] tracking-tight text-[#1A1A24] mb-5">
                Vuoi uno spazio<br class="hidden sm:block" />
                <span class="text-accent">come questi?</span>
              </h2>
              <p class="text-[#555] text-base leading-relaxed max-w-lg mx-auto mb-10">
                Ti affianchiamo dalla progettazione all'apertura. Raccontaci la tua idea.
              </p>
              <a
                href="/#contatti"
                class="cta-shine group inline-flex items-center gap-2 px-9 py-4 bg-accent text-bg font-body font-bold text-base rounded-xl transition-all duration-300 hover:shadow-[0_0_40px_rgba(245,166,35,0.35)]"
              >
                <span>Parliamone insieme</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-transform duration-300 group-hover:translate-x-1">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </section>

        </div>
      </div>
    </div>
  </main>

  <!-- ══ LIGHTBOX MODAL ══ -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true">
    <button id="lb-close" class="lb-close" aria-label="Chiudi">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
    <div id="lb-inner" class="lb-inner"></div>
    <button id="lb-prev" class="lb-nav lb-prev" aria-label="Precedente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button id="lb-next" class="lb-nav lb-next" aria-label="Successivo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <Footer />
</Layout>

<style>
  /* ── Hero gradient text ── */
  .h24-gradient {
    background: linear-gradient(135deg, #F5A623 0%, #FFD080 50%, #F5A623 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Video grid ── */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    /* Make first video span 2 cols */
    .video-card:first-child {
      grid-column: span 2;
    }
  }

  .video-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 9/16;
    background: #111;
    border: 1px solid rgba(0,0,0,0.06);
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s ease;
  }

  @media (min-width: 768px) {
    .video-card:first-child {
      aspect-ratio: 16/9;
    }
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.15), 0 0 0 2px rgba(245,166,35,0.25);
  }

  .video-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .video-card:hover .video-thumb {
    transform: scale(1.04);
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 16px;
    transition: background 0.4s ease;
  }

  .video-card:hover .video-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 50%, transparent 100%);
  }

  .video-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    color: rgba(245,166,35,0.35);
    line-height: 1;
    transition: color 0.3s ease;
    text-align: left;
  }

  .video-card:hover .video-num {
    color: rgba(245,166,35,0.6);
  }

  .play-btn {
    align-self: flex-end;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(245,166,35,0.9);
    color: #0A0A0F;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: scale(0.85);
    opacity: 0.7;
    transition: all 0.3s ease;
    backdrop-filter: blur(8px);
  }

  .video-card:hover .play-btn {
    transform: scale(1);
    opacity: 1;
    background: #F5A623;
    box-shadow: 0 0 24px rgba(245,166,35,0.5);
  }

  /* ── Photo masonry ── */
  .photo-masonry {
    columns: 2;
    column-gap: 14px;
  }

  @media (min-width: 640px) {
    .photo-masonry {
      columns: 3;
      column-gap: 16px;
    }
  }

  @media (min-width: 1024px) {
    .photo-masonry {
      columns: 4;
      column-gap: 18px;
    }
  }

  .photo-card {
    break-inside: avoid;
    display: block;
    width: 100%;
    margin-bottom: 14px;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    position: relative;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s ease;
  }

  @media (min-width: 640px) {
    .photo-card {
      margin-bottom: 16px;
    }
  }

  @media (min-width: 1024px) {
    .photo-card {
      margin-bottom: 18px;
    }
  }

  .photo-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.13), 0 0 0 2px rgba(245,166,35,0.2);
  }

  .photo-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  .photo-card:hover .photo-img {
    transform: scale(1.04);
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,15,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(2px);
  }

  .photo-card:hover .photo-overlay {
    opacity: 1;
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(5,5,8,0.97);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    backdrop-filter: blur(16px);
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: all;
  }

  .lb-inner {
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb-inner img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    display: block;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6);
  }

  .lb-inner video {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: 8px;
    display: block;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6);
  }

  .lb-close {
    position: fixed;
    top: 20px;
    right: 24px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    z-index: 10;
  }

  .lb-close:hover {
    background: rgba(245,166,35,0.2);
    border-color: rgba(245,166,35,0.4);
    transform: rotate(90deg);
  }

  .lb-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    z-index: 10;
  }

  .lb-nav:hover {
    background: rgba(245,166,35,0.2);
    border-color: rgba(245,166,35,0.4);
  }

  .lb-prev { left: 20px; }
  .lb-next { right: 20px; }

  /* ── Partner strip ── */
  .partner-track-wrap {
    position: relative;
    overflow: hidden;
  }

  .partner-fade-left,
  .partner-fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }
  .partner-fade-left  { left: 0;  background: linear-gradient(to right, #FAFAF7, transparent); }
  .partner-fade-right { right: 0; background: linear-gradient(to left,  #FAFAF7, transparent); }

  .partner-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: scroll-left 28s linear infinite;
  }

  .partner-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .partner-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 48px;
    height: 72px;
    flex-shrink: 0;
  }

  .partner-item img {
    height: 40px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(1) opacity(0.5);
    transition: filter 0.3s ease;
  }

  .partner-item img:hover {
    filter: grayscale(0) opacity(1);
  }

  /* ── CTA shine ── */
  .cta-shine {
    position: relative;
    overflow: hidden;
  }
  .cta-shine::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }
  .cta-shine:hover::before {
    transform: translateX(100%);
  }
</style>

<script>
  // ── Scroll reveal ──
  const revealObs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('revealed'); revealObs.unobserve(e.target); }
    }),
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => revealObs.observe(el));

  // ── Molding scroll ──
  const molding = document.getElementById('molding');
  if (molding) {
    const content = molding.querySelector('.molding-content') as HTMLElement;
    window.addEventListener('scroll', () => {
      const progress = Math.min(1, Math.max(0, window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)));
      const m = 15 * (1 - progress);
      const r = 50 * (1 - progress);
      molding.style.marginLeft = `${m}%`;
      molding.style.marginRight = `${m}%`;
      molding.style.borderRadius = `${r}px ${r}px 0 0`;
      if (content) content.style.borderRadius = `${Math.max(0, r - 2)}px ${Math.max(0, r - 2)}px 0 0`;
    }, { passive: true });
  }

  // ── Video hover preview ──
  document.querySelectorAll<HTMLButtonElement>('.video-card').forEach((card) => {
    const vid = card.querySelector('video')!;
    card.addEventListener('mouseenter', () => { vid.play().catch(() => {}); });
    card.addEventListener('mouseleave', () => { vid.pause(); vid.currentTime = 0; });
  });

  // ── Lightbox ──
  const lightbox = document.getElementById('lightbox')!;
  const lbInner  = document.getElementById('lb-inner')!;
  const lbClose  = document.getElementById('lb-close')!;
  const lbPrev   = document.getElementById('lb-prev')!;
  const lbNext   = document.getElementById('lb-next')!;

  // Build unified item list: videos first, then photos
  const videoCards = Array.from(document.querySelectorAll<HTMLButtonElement>('.video-card'));
  const photoCards = Array.from(document.querySelectorAll<HTMLButtonElement>('.photo-card'));

  type LBItem = { type: 'video' | 'photo'; src: string };
  const items: LBItem[] = [
    ...videoCards.map(c => ({ type: 'video' as const, src: c.dataset.src! })),
    ...photoCards.map(c => ({ type: 'photo' as const, src: c.dataset.src! })),
  ];

  let current = 0;
  let activeVideo: HTMLVideoElement | null = null;

  function openLightbox(idx: number) {
    current = idx;
    render();
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (activeVideo) { activeVideo.pause(); activeVideo = null; }
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
    setTimeout(() => { lbInner.innerHTML = ''; }, 350);
  }

  function render() {
    if (activeVideo) { activeVideo.pause(); activeVideo = null; }
    lbInner.innerHTML = '';
    const item = items[current];
    if (item.type === 'video') {
      const v = document.createElement('video');
      v.src = item.src;
      v.controls = true;
      v.autoplay = true;
      v.playsInline = true;
      lbInner.appendChild(v);
      activeVideo = v;
    } else {
      const img = document.createElement('img');
      img.src = item.src;
      img.alt = '';
      lbInner.appendChild(img);
    }
    lbPrev.style.display = current === 0 ? 'none' : 'flex';
    lbNext.style.display = current === items.length - 1 ? 'none' : 'flex';
  }

  // Wire video cards
  videoCards.forEach((card, i) => {
    card.addEventListener('click', () => openLightbox(i));
  });

  // Wire photo cards
  photoCards.forEach((card, i) => {
    card.addEventListener('click', () => openLightbox(videoCards.length + i));
  });

  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', () => { if (current > 0) { current--; render(); } });
  lbNext.addEventListener('click', () => { if (current < items.length - 1) { current++; render(); } });

  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft' && current > 0) { current--; render(); }
    if (e.key === 'ArrowRight' && current < items.length - 1) { current++; render(); }
  });
</script>
