---
---

<section class="hero-section relative min-h-screen flex items-center justify-center overflow-hidden pt-20" id="hero">
  <!-- Background image with darkening -->
  <div class="absolute inset-0">
    <img src="/heroimg.png" alt="" class="w-full h-full object-cover object-center brightness-[0.55]" />
  </div>

  <!-- Grain overlay — vintage look -->
  <div class="hero-grain absolute inset-0 pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center flex flex-col items-center">
    <!-- Headline -->
    <div class="mb-7 flex flex-col items-center gap-1 animate-fade-up" style="animation-delay: 0.2s;">
      <span class="hero-headline font-display font-extrabold text-[clamp(2.3rem,5.25vw,5rem)] leading-[1.05] tracking-tight text-white">Trasformiamo spazi vuoti</span>
      <span class="hero-accent-text font-display font-extrabold text-[clamp(2.3rem,5.25vw,5rem)] leading-[0.92] tracking-tight" style="margin-top: 4px;">in business attivi 24/7.</span>
    </div>

    <!-- Description -->
    <div class="mb-11 max-w-xl animate-fade-up" style="animation-delay: 0.45s;">
      <p class="hero-desc text-lg md:text-xl leading-relaxed text-white">
        Dal primo distributore al negozio automatico completo: consulenza strategica, installazione e supporto tecnico continuo per far crescere il tuo business.
      </p>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up" style="animation-delay: 0.7s;">
      <a href="#contatti" class="hero-cta-primary group px-9 py-4 bg-accent text-bg font-body font-bold text-base rounded-xl transition-all duration-400">
        <span class="flex items-center gap-2">
          Richiedi Informazioni
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-transform duration-300 group-hover:translate-x-1">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
      <a href="#servizi" class="hero-cta-secondary px-9 py-4 font-body font-medium text-base text-white rounded-xl transition-all duration-400">
        Esplora i servizi
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-float opacity-40">
    <div class="w-[22px] h-[34px] border-[1.5px] border-white/30 rounded-full flex items-start justify-center pt-2">
      <div class="w-[3px] h-[6px] bg-accent rounded-full animate-[fade-up_1.8s_ease-in-out_infinite]"></div>
    </div>
  </div>
</section>

<style>
  /* Rounded bottom corners */
  .hero-section {
    border-radius: 0 0 48px 48px;
  }

  /* Grain texture over hero image — vintage feel */
  .hero-grain {
    z-index: 1;
    opacity: 0.22;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='5' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px 180px;
    mix-blend-mode: overlay;
  }

  /*
   * Headline contrast — layered text-shadow creates a dark "halo"
   * around each letter. No overlay needed, the shadow is baked
   * into the glyphs themselves so the image stays fully visible.
   */
  .hero-headline {
    text-shadow:
      0 2px 4px rgba(0, 0, 0, 0.9),
      0 4px 16px rgba(0, 0, 0, 0.7),
      0 8px 40px rgba(0, 0, 0, 0.5),
      0 0 80px rgba(0, 0, 0, 0.3);
  }

  /* Gold text — drop-shadow version (text-shadow doesn't work with background-clip) */
  .hero-accent-text {
    background: linear-gradient(135deg, #F5A623 0%, #FFD080 50%, #F5A623 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter:
      drop-shadow(0 2px 3px rgba(0, 0, 0, 0.85))
      drop-shadow(0 4px 12px rgba(0, 0, 0, 0.6))
      drop-shadow(0 8px 32px rgba(0, 0, 0, 0.4));
  }

  /* Subtitle shadow — lighter touch */
  .hero-desc {
    text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.8),
      0 4px 16px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(0, 0, 0, 0.3);
  }

  /* Primary CTA glow */
  .hero-cta-primary {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }
  .hero-cta-primary:hover {
    box-shadow: 0 4px 40px rgba(245, 166, 35, 0.35);
    background-color: #FFB940;
  }

  /* Secondary CTA — frosted glass look */
  .hero-cta-secondary {
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }
  .hero-cta-secondary:hover {
    background: rgba(0, 0, 0, 0.35);
    border-color: rgba(255, 255, 255, 0.3);
  }
</style>
