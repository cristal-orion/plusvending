---
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Plus Vending — Distributori Automatici',
  description = 'Vendita, riparazione distributori automatici e progettazione negozi H24. Consulenza e assistenza tecnica in Campania.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <!-- Google Consent Mode v2 — default denied, updated by CookieBanner -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;

      // Honor stored preferences if the user already chose
      var stored = null;
      try { stored = JSON.parse(localStorage.getItem('pv_consent_v1')); } catch(e) {}

      var defaults = {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'granted',
        personalization_storage: 'denied',
        security_storage: 'granted',
      };

      if (stored && stored.choices) {
        defaults.analytics_storage = stored.choices.statistics ? 'granted' : 'denied';
        defaults.ad_storage = stored.choices.marketing ? 'granted' : 'denied';
        defaults.ad_user_data = stored.choices.marketing ? 'granted' : 'denied';
        defaults.ad_personalization = stored.choices.marketing ? 'granted' : 'denied';
      }

      gtag('consent', 'default', defaults);
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PJZBQXMX');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0A0F" />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://plusvending.it" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://plusvending.it" />
    <meta property="og:image" content="https://plusvending.it/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Plus Vending",
        "description": "Vendita, riparazione distributori automatici e progettazione negozi H24 in Campania.",
        "url": "https://plusvending.it",
        "telephone": "+390810000000",
        "email": "info@plusvending.it",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Napoli",
          "addressRegion": "Campania",
          "addressCountry": "IT"
        },
        "areaServed": {
          "@type": "State",
          "name": "Campania"
        },
        "priceRange": "€€"
      }
    </script>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-bg text-text font-body grain antialiased overflow-x-hidden relative">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PJZBQXMX"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- Subtle ambient background glow (hero only) -->
    <div class="fixed inset-0 pointer-events-none z-[-1]">
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[40%] rounded-full bg-accent/5 blur-[120px] mix-blend-screen"></div>
    </div>
    
    <slot />

    <CookieBanner />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

      // Molding scroll animation — starts narrow, expands to full width
      const molding = document.getElementById('molding');
      if (molding) {
        const content = molding.querySelector('.molding-content') as HTMLElement;
        const startMargin = 15; // % — initial side margin
        const startRadius = 50; // px
        window.addEventListener('scroll', () => {
          const docH = document.documentElement.scrollHeight - window.innerHeight;
          const progress = Math.min(1, Math.max(0, window.scrollY / docH));
          const margin = startMargin * (1 - progress);
          const radius = startRadius * (1 - progress);
          molding.style.marginLeft = `${margin}%`;
          molding.style.marginRight = `${margin}%`;
          molding.style.borderRadius = `${radius}px ${radius}px 0 0`;
          if (content) {
            content.style.borderRadius = `${Math.max(0, radius - 2)}px ${Math.max(0, radius - 2)}px 0 0`;
          }
        }, { passive: true });
      }
    </script>
  </body>
</html>
