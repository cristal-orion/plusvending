---
---

<footer class="relative pt-20 pb-10">
  <!-- Divider -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[min(80%,600px)] h-px bg-gradient-to-r from-transparent via-[#ddd] to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-10 mb-16">
      <!-- Logo & tagline -->
      <div class="flex items-center gap-3">
        <svg width="28" height="34" viewBox="0 0 40 48" fill="none">
          <rect x="0" y="0" width="40" height="48" rx="3" fill="#F5A623" />
          <rect x="6" y="6" width="28" height="36" rx="2" fill="#FAFAF7" />
          <rect x="11" y="11" width="18" height="26" rx="1.5" fill="#F5A623" />
          <rect x="16" y="16" width="8" height="16" rx="1" fill="#FAFAF7" />
        </svg>
        <div>
          <span class="font-display font-bold text-base tracking-tight text-[#1A1A24] leading-none block">
            PLUS <span class="text-accent">VENDING</span>
          </span>
          <span class="text-[11px] text-[#999] tracking-wide">Distributori Automatici</span>
        </div>
      </div>

      <!-- Quick links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        <a href="#servizi" class="text-[13px] text-[#555] hover:text-accent transition-colors duration-300">Servizi</a>
        <a href="#perche-noi" class="text-[13px] text-[#555] hover:text-accent transition-colors duration-300">Perché noi</a>
        <a href="#chi-siamo" class="text-[13px] text-[#555] hover:text-accent transition-colors duration-300">Chi siamo</a>
        <a href="#contatti" class="text-[13px] text-[#555] hover:text-accent transition-colors duration-300">Contatti</a>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-black/[0.06]">
      <p class="text-[12px] text-[#999] text-center md:text-left">
        &copy; {new Date().getFullYear()} Plus Vending s.r.l.s — P.IVA 05764060652
      </p>
      <p class="text-[12px] text-[#bbb]">
        Via Alfonso Albanese, 43 — 84010 S.Egidio del Monte Albino (SA)
      </p>
    </div>
  </div>
</footer>
