---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const categorie = [
  {
    id: 'snack-bevande',
    tag: 'Snack & Bevande',
    title: 'Soluzioni di refreshment sempre disponibili',
    image: '/snackebevande.webp',
    description: 'Distributori automatici progettati per uffici, aree comuni, palestre e location ad alta frequentazione. Ogni configurazione integra refrigerazione avanzata e display touch per un\'esperienza d\'acquisto fluida.',
    features: ['Refrigerazione regolabile', 'Display touch interattivo', 'Caricamento frontale o posteriore', 'Compatibilità sistemi cashless'],
    accent: 'from-amber-500/20 to-orange-600/20',
  },
  {
    id: 'caffe',
    tag: 'Caffè',
    title: 'L\'eccellenza del caffè in ogni momento',
    image: '/caffèespresso.webp',
    description: 'Macchine di ultima generazione come il G-Caffè UNI-Q Touch: display touch da 18.5 pollici con interfaccia intuitiva, integrabile con distributori Slave per creare stazioni complete bevande + snack.',
    features: ['Display touch 18.5" con UI accessibile', 'Visualizzazione valori nutrizionali', 'Configurazione Master-Slave', 'Layout grafici personalizzabili'],
    accent: 'from-amber-700/20 to-yellow-900/20',
  },
  {
    id: 'carne-frozen',
    tag: 'Carne & Frozen',
    title: 'Qualità e sicurezza alimentare',
    image: '/frozen.webp',
    description: 'Il modello SBX-H2 Back Loader Master 10 garantisce la vendita di carne fresca e surgelati in totale sicurezza. Sistema di caricamento posteriore per rifornimento rapido, controllo temperatura costante tra +2°C e +10°C. Configurabile anche per farmacie e panetterie.',
    features: ['Back-loading senza interruzione catena del freddo', 'Fino a 60 selezioni su 4-6 ripiani', 'Controllo elettronico refrigerante HC2', 'Protocollo Executive/MDB'],
    accent: 'from-sky-500/20 to-cyan-600/20',
  },
  {
    id: 'gelati',
    tag: 'Gelati',
    title: 'Freschezza garantita 24/7',
    image: '/gelati.webp',
    description: 'Sistemi di refrigerazione avanzata che mantengono la temperatura ottimale per la conservazione del gelato. Ideali per località turistiche, stabilimenti balneari, centri commerciali e negozi H24.',
    features: ['Refrigerazione a temperatura negativa', 'Vetrina illuminata per visibilità prodotto', 'Sistema anti-sbrinamento', 'Ideale per alto traffico stagionale'],
    accent: 'from-pink-400/20 to-fuchsia-500/20',
  },
  {
    id: 'giochi',
    tag: 'Giochi',
    title: 'Intrattenimento che attira e fidelizza',
    image: '/giochi.webp',
    description: 'Distributori dedicati a giocattoli, peluche e gadget con design ad alta attrattiva visiva. Perfetti per centri commerciali, sale giochi, aree family e negozi H24. Configurazioni multiple: sistemi a gru o selezione diretta.',
    features: ['Alta attrattiva visuale con illuminazione LED', 'Sistemi a gru o selezione diretta', 'Struttura robusta e antivandalismo', 'Personalizzazione grafica completa'],
    accent: 'from-violet-500/20 to-purple-600/20',
    iconPath: 'M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<Layout
  title="Distributori Automatici — Plus Vending"
  description="Scopri la nostra gamma completa di distributori automatici: caffè, snack e bevande, carne e frozen, gelati e giochi. Vendita e consulenza in Campania."
>
  <Header />

  <main>
    <!-- ══ HERO BANNER ══ -->
    <section class="dist-hero relative min-h-[70vh] md:min-h-[60vh] flex items-end overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0 bg-bg">
        <div class="absolute inset-0 bg-gradient-to-b from-accent/8 via-transparent to-bg"></div>
        <!-- Geometric pattern -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 60px, rgba(245,166,35,0.5) 60px, rgba(245,166,35,0.5) 61px);"></div>
      </div>

      <!-- Floating accent shapes -->
      <div class="absolute top-20 right-[10%] w-72 h-72 rounded-full bg-accent/[0.04] blur-[80px] animate-float"></div>
      <div class="absolute bottom-20 left-[5%] w-96 h-96 rounded-full bg-accent/[0.03] blur-[100px] animate-float" style="animation-delay: -2.5s;"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 pb-20 pt-32 w-full">
        <div class="animate-fade-up" style="animation-delay: 0.15s;">
          <p class="text-[11px] font-body font-semibold tracking-[0.25em] uppercase text-accent mb-5">La nostra gamma</p>
          <h1 class="font-display font-extrabold text-5xl md:text-[4.5rem] lg:text-[5.5rem] leading-[1.02] tracking-tight text-text mb-6">
            Soluzioni complete<br/>
            <span class="dist-hero-accent">per ogni settore</span>
          </h1>
          <p class="text-lg md:text-xl text-text-muted max-w-xl leading-relaxed">
            Bevande calde, surgelati, snack, giocattoli: la tecnologia automatica che risponde a tutte le esigenze del tuo business.
          </p>
        </div>

        <!-- Category quick-nav pills -->
        <nav class="dist-pills mt-12 flex flex-wrap gap-3 animate-fade-up" style="animation-delay: 0.5s;">
          {categorie.map((cat) => (
            <a
              href={`#${cat.id}`}
              class="dist-pill px-5 py-2.5 text-[13px] font-medium tracking-wide rounded-full border border-white/10 text-white/70 hover:text-accent hover:border-accent/40 transition-all duration-300 backdrop-blur-sm bg-white/[0.03]"
            >
              {cat.tag}
            </a>
          ))}
        </nav>
      </div>

      <!-- Bottom fade into content area -->
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-accent to-transparent"></div>
    </section>

    <!-- ══ CONTENT AREA (inside molding) ══ -->
    <div class="molding-outer">
      <div class="molding-wrapper" id="molding">
        <div class="molding-content">

          <!-- Category sections -->
          {categorie.map((cat, idx) => (
            <section id={cat.id} class="dist-section relative py-24 md:py-32 overflow-hidden">
              {/* Divider (not on first) */}
              {idx > 0 && (
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[min(80%,600px)] h-px bg-gradient-to-r from-transparent via-[#ddd] to-transparent"></div>
              )}

              <div class="max-w-6xl mx-auto px-6">
                <div class={`flex flex-col ${idx % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-12 lg:gap-20 items-center`}>

                  {/* Image */}
                  <div class="dist-img-wrap w-full lg:w-1/2" data-reveal>
                    <img
                      src={cat.image}
                      alt={cat.title}
                      class="w-full h-auto object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.12)] transition-transform duration-700 hover:scale-105"
                      loading="lazy"
                    />
                  </div>

                  {/* Text content */}
                  <div class="w-full lg:w-1/2" data-reveal={`delay-${idx % 2 === 0 ? '2' : '1'}`}>
                    <span class="inline-block px-4 py-1.5 text-[11px] font-semibold tracking-[0.2em] uppercase text-accent bg-accent/[0.08] rounded-full mb-5">
                      {cat.tag}
                    </span>
                    <h2 class="font-display font-bold text-3xl md:text-[2.6rem] leading-[1.1] tracking-tight text-[#1A1A24] mb-5">
                      {cat.title}
                    </h2>
                    <p class="text-[#555] text-[15px] md:text-base leading-relaxed mb-8">
                      {cat.description}
                    </p>

                    {/* Features */}
                    <ul class="space-y-3 mb-10">
                      {cat.features.map((feat) => (
                        <li class="flex items-start gap-3">
                          <span class="dist-check mt-1 w-5 h-5 rounded-md bg-accent/10 flex items-center justify-center flex-shrink-0">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M5 13l4 4L19 7" />
                            </svg>
                          </span>
                          <span class="text-[14px] text-[#444] leading-snug">{feat}</span>
                        </li>
                      ))}
                    </ul>

                    <a
                      href="/#contatti"
                      class="dist-cta group inline-flex items-center gap-2 px-7 py-3.5 bg-accent text-bg font-body font-semibold text-sm rounded-xl transition-all duration-300 hover:shadow-[0_0_32px_rgba(245,166,35,0.3)]"
                    >
                      <span>Richiedi informazioni</span>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="transition-transform duration-300 group-hover:translate-x-1">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </section>
          ))}

          <!-- ══ CTA BOTTOM BANNER ══ -->
          <section class="relative py-24 md:py-28 overflow-hidden">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[min(80%,600px)] h-px bg-gradient-to-r from-transparent via-[#ddd] to-transparent"></div>

            <div class="max-w-4xl mx-auto px-6 text-center" data-reveal>
              <p class="text-[11px] font-body font-semibold tracking-[0.22em] uppercase text-accent mb-4">Hai bisogno di consulenza?</p>
              <h2 class="font-display font-bold text-3xl md:text-[2.8rem] leading-[1.1] tracking-tight text-[#1A1A24] mb-5">
                Identifica la soluzione<br class="hidden sm:block" />
                <span class="text-accent">ideale per il tuo business</span>
              </h2>
              <p class="text-[#555] text-base leading-relaxed max-w-lg mx-auto mb-10">
                Contattaci per una consulenza gratuita: ti guidiamo verso il distributore che massimizza il rendimento del tuo spazio.
              </p>
              <a
                href="/#contatti"
                class="dist-cta group inline-flex items-center gap-2 px-9 py-4 bg-accent text-bg font-body font-bold text-base rounded-xl transition-all duration-300 hover:shadow-[0_0_40px_rgba(245,166,35,0.35)]"
              >
                <span>Parliamone insieme</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-transform duration-300 group-hover:translate-x-1">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </section>

        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero accent text ─────────────────────── */
  .dist-hero-accent {
    background: linear-gradient(135deg, #F5A623 0%, #FFD080 50%, #F5A623 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Pill hover glow ──────────────────────── */
  .dist-pill:hover {
    background: rgba(245, 166, 35, 0.06);
    box-shadow: 0 0 20px rgba(245, 166, 35, 0.08);
  }

  /* ── CTA shine effect ─────────────────────── */
  .dist-cta {
    position: relative;
    overflow: hidden;
  }
  .dist-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }
  .dist-cta:hover::before {
    transform: translateX(100%);
  }

  /* ── Alternating section subtle bg ────────── */
  .dist-section:nth-child(even) {
    background: linear-gradient(180deg, transparent, rgba(245, 166, 35, 0.015), transparent);
  }

  /* ── Smooth scroll offset for anchors ─────── */
  .dist-section {
    scroll-margin-top: 5rem;
  }
</style>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

  // Molding scroll animation
  const molding = document.getElementById('molding');
  if (molding) {
    const content = molding.querySelector('.molding-content') as HTMLElement;
    const startMargin = 15;
    const startRadius = 50;
    window.addEventListener('scroll', () => {
      const docH = document.documentElement.scrollHeight - window.innerHeight;
      const progress = Math.min(1, Math.max(0, window.scrollY / docH));
      const margin = startMargin * (1 - progress);
      const radius = startRadius * (1 - progress);
      molding.style.marginLeft = `${margin}%`;
      molding.style.marginRight = `${margin}%`;
      molding.style.borderRadius = `${radius}px ${radius}px 0 0`;
      if (content) {
        content.style.borderRadius = `${Math.max(0, radius - 2)}px ${Math.max(0, radius - 2)}px 0 0`;
      }
    }, { passive: true });
  }
</script>
